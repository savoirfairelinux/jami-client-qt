+++ b/qtwebengine/src/3rdparty/chromium/cc/input/main_thread_scrolling_reason.h
@@ -5,6 +5,7 @@
 #ifndef CC_INPUT_MAIN_THREAD_SCROLLING_REASON_H_
 #define CC_INPUT_MAIN_THREAD_SCROLLING_REASON_H_
 
+#include <cstdint>
 #include <memory>
 #include <string>
 #include "cc/cc_export.h"
diff --git a/qtwebengine/src/3rdparty/chromium/extensions/common/stack_frame.h b/qtwebengine/src/3rdparty/chromium/extensions/common/stack_frame.h
index dd7d77836f..0f210ef207 100644
--- a/qtwebengine/src/3rdparty/chromium/extensions/common/stack_frame.h
+++ b/qtwebengine/src/3rdparty/chromium/extensions/common/stack_frame.h
@@ -7,6 +7,7 @@
 
