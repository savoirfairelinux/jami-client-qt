From 45237a5cf76bccc8fe4b70be2aa8fe8459f6da29 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Fran=C3=A7ois-Simon=20Fauteux-Chapleau?=
 <francois-simon.fauteux-chapleau@savoirfairelinux.com>
Date: Tue, 28 Apr 2026 13:06:11 -0400
Subject: [PATCH] qtwebengine: add missing header includes in chromium
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Chromium's build fails on Fedora 44 because of undeclared types, e.g.:

    In file included from ../../../3rdparty/chromium/third_party/perfetto/include/perfetto/ext/tracing/core/trace_packet.h:27,
                     from ../../../3rdparty/chromium/third_party/perfetto/src/tracing/core/trace_packet.cc:17:
    ../../../3rdparty/chromium/third_party/perfetto/include/perfetto/ext/tracing/core/slice.h:47:46: error: ‘uint8_t’ was not declared in this scope
       47 |   static Slice TakeOwnership(std::unique_ptr<uint8_t[]> buf, size_t size) {
          |

This is probably due to standard library header changes in GCC 16.
---
 .../src/3rdparty/chromium/net/tools/huffman_trie/trie_entry.h    | 1 +
 .../perfetto/include/perfetto/ext/tracing/core/slice.h           | 1 +
 2 files changed, 2 insertions(+)

diff --git a/qtwebengine/src/3rdparty/chromium/net/tools/huffman_trie/trie_entry.h b/qtwebengine/src/3rdparty/chromium/net/tools/huffman_trie/trie_entry.h
index 6fc6933b0c..fbf1787803 100644
--- a/qtwebengine/src/3rdparty/chromium/net/tools/huffman_trie/trie_entry.h
+++ b/qtwebengine/src/3rdparty/chromium/net/tools/huffman_trie/trie_entry.h
@@ -5,6 +5,7 @@
 #ifndef NET_TOOLS_HUFFMAN_TRIE_TRIE_ENTRY_H_
 #define NET_TOOLS_HUFFMAN_TRIE_TRIE_ENTRY_H_
 
+#include <cstdint>
 #include <memory>
 #include <string>
 #include <vector>
diff --git a/qtwebengine/src/3rdparty/chromium/third_party/perfetto/include/perfetto/ext/tracing/core/slice.h b/qtwebengine/src/3rdparty/chromium/third_party/perfetto/include/perfetto/ext/tracing/core/slice.h
index 063043bdc6..6564ca89cd 100644
--- a/qtwebengine/src/3rdparty/chromium/third_party/perfetto/include/perfetto/ext/tracing/core/slice.h
+++ b/qtwebengine/src/3rdparty/chromium/third_party/perfetto/include/perfetto/ext/tracing/core/slice.h
@@ -20,6 +20,7 @@
 #include <stddef.h>
 #include <string.h>
 
+#include <cstdint>
 #include <memory>
 #include <string>
 #include <vector>
-- 
2.43.0

