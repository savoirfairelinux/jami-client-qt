{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "run-tests",
            "type": "shell",
            "command": "ctest",
            "options": {
                "cwd": "${workspaceFolder}/build/tests",
                "env": {
                    "HOME": "/tmp"
                }
            },
            "args": [
                "-V",
                "-R"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "detail": "Run the tests using CTest."
        },
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset", "${input:configurePreset}"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Configure with a CMake preset."
        },
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "--preset", "${input:buildPreset}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build with a CMake preset."
        },
        {
            "label": "cmake-clean",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "build"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean the build directory."
        }
    ],
    "inputs": [
        {
            "id": "configurePreset",
            "type": "pickString",
            "description": "Select a configure preset",
            "options": ["debug", "debug-dbus", "release"],
            "default": "debug"
        },
        {
            "id": "buildPreset",
            "type": "pickString",
            "description": "Select a build preset",
            "options": ["debug", "debug-dbus", "release"],
            "default": "debug"
        }
    ]
}