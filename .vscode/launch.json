{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Jami-Client-Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "",
            "linux": {
                "MIMode": "gdb",
                "program": "${workspaceFolder}/build/jami",
                "args": [
                    "-d"
                ]
            },
            "osx": {
                "MIMode": "lldb",
                "program": "${workspaceFolder}/build/Jami.app/Contents/MacOS/Jami",
                "environment": [
                    {
                        "name": "NO_COLOR",
                        "value": "true"
                    }
                ]
            },
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake-build",
            "externalConsole": false,
            "visualizerFile": "c:\\Users\\atraczyk\\AppData\\Roaming\\Code\\User\\workspaceStorage\\3d64cb3481b9f352bbf4d192f9fca9fc\\tonka3000.qtvsctools\\qt.natvis.xml"
        },
        {
            "name": "Jami-Daemon-Debug",
            "type": "cppdbg",
            "request": "launch",
            "linux": {
                "MIMode": "gdb",
                "program": "${workspaceFolder}/daemon/bin/dbus/jamid"
            },
            "program": "",
            "args": [
                "-cdp"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake-build",
            "visualizerFile": "c:\\Users\\atraczyk\\AppData\\Roaming\\Code\\User\\workspaceStorage\\3d64cb3481b9f352bbf4d192f9fca9fc\\tonka3000.qtvsctools\\qt.natvis.xml"
